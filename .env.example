# ============================================================
# LAWNOVA — Root Environment Variables
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================================

# -------------------- MongoDB --------------------
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?appName=<appName>
MONGODB_USER=your_db_user
MONGODB_PASSWORD=your_db_password

# -------------------- JWT Authentication --------------------
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRY=7d
JWT_EXPIRES_IN=7d
RESET_TOKEN_EXPIRY=15m
VERIFICATION_TOKEN_EXPIRY=24h

# -------------------- Email Configuration --------------------
EMAIL_SERVICE=gmail
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_PASSWORD=your_app_password
EMAIL_FROM=your-email@gmail.com

# -------------------- Service Ports --------------------
API_GATEWAY_PORT=5000
AUTH_SERVICE_PORT=5005
MOCKTRIAL_SERVICE_PORT=10004
USER_SERVICE_PORT=5005
SCHEDULING_SERVICE_PORT=5003
PORT=5001

# -------------------- Frontend URLs --------------------
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:5005
NEXT_PUBLIC_MOCKTRIAL_URL=http://localhost:10004
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000

# -------------------- CORS Configuration --------------------
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# -------------------- File Upload Configuration --------------------
MAX_FILE_SIZE=100000000
UPLOAD_DIR=./uploads
EVIDENCE_UPLOAD_DIR=uploads/evidence
RECORDING_UPLOAD_DIR=uploads/recordings

# -------------------- Session Configuration --------------------
SESSION_TIMEOUT_MINUTES=120
SESSION_DURATION=7200000
INVITATION_EXPIRY_DAYS=7

# -------------------- Development --------------------
NODE_ENV=development
DEBUG=true
LOG_LEVEL=debug
BCRYPT_ROUNDS=10

# -------------------- Docker Deployment --------------------
# Used by docker-compose image names on EC2.
DOCKERHUB_USERNAME=your_dockerhub_username

# Used by AI service.
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX=your_pinecone_index_name

# Used by mocktrial service.
VIDEOSDK_API_KEY=your_videosdk_api_key
VIDEOSDK_SECRET=your_videosdk_secret

# Used by AI/judgment/roleplay services.
GEMINI_API_KEY=your_gemini_api_key
