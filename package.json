{
  "name": "lawnova-webapp",
  "version": "1.0.0",
  "description": "Legal Learning Scheduler & Mock Trial Portal",
  "type": "module",
  "main": "api-gateway/server.js",
  "scripts": {
    "start": "node api-gateway/server.js",
    "dev": "nodemon api-gateway/server.js",
    "start-all": "concurrently --delay 2000 -p \"[{name}]\" -n \"Frontend,Gateway,User,Roleplay,MockTrial,AINode,AIPython,Drafting\" -c \"cyan,yellow,green,blue,magenta,red,white,gray\" --kill-others \"npm run start:web\" \"npm run start:gateway\" \"npm run dev:user\" \"npm run dev:roleplay\" \"npm run dev:mocktrial\" \"npm run dev:ai\" \"npm run start:aipython\" \"npm run start:drafting\"",
    "kill-ports": "npx kill-port 3000 5000 5001 5002 5003 5004 5005 5006 5007 5008 5009 10004 10005 8000 8001",
    "start:web": "cd web-client && npm run dev",
    "start:gateway": "cd api-gateway && npm run dev",
    "dev:user": "cd services/user-service && npm run dev",
    "dev:roleplay": "cd services/roleplay-service && npm run dev",
    "dev:mocktrial": "cd services/mocktrial-service && npm run dev",
    "dev:ai": "cd services/ai-service && npm run dev",
    "start:user": "cd services/user-service && npm start",
    "start:roleplay": "cd services/roleplay-service && npm start",
    "start:mocktrial": "cd services/mocktrial-service && npm start",
    "start:ai": "cd services/ai-service && npm start",
    "start:aipython": "cd services/ai-service && scripts\\.venv\\Scripts\\python app.py",
    "start:drafting": "cd services/drafting-service && python -m uvicorn src.api:app --reload --host 0.0.0.0 --port 8001"
  },
  "nodemonConfig": {
    "ignore": [
      "*.log",
      "*.jsonl",
      "LAWNOVA_FINAL_BRAIN_V2/*",
      "**/temp/**",
      "services/ai-service/logs/*"
    ]
  },
  "keywords": [
    "legal",
    "mock-trial",
    "education",
    "scheduling"
  ],
  "author": "Lawnova Team",
  "license": "MIT",
  "dependencies": {
    "@chroma-core/default-embed": "^0.1.9",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.5.1",
    "helmet": "^7.1.0",
    "http-proxy-middleware": "^2.0.6",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.555.0",
    "mongoose": "^8.0.0",
    "multer": "^2.0.2",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.7",
    "socket.io": "^4.7.2",
    "uuid": "^9.0.1",
    "winston": "^3.19.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  }
}
