# Server Configuration
PORT=10005
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?appName=<appName>

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_KEY1=your_gemini_api_key_backup_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# JWT Secret
JWT_SECRET=your_jwt_secret_here

# Service Name
SERVICE_NAME=roleplay-service

# Inter-Service Communication URLs
USER_SERVICE_URL=http://localhost:5005
AI_SERVICE_URL=http://localhost:5009
API_GATEWAY_URL=http://localhost:5000

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:5000

# OpenAI Model Configuration
OPENAI_MODEL=gpt-3.5
