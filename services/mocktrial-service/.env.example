# Server Configuration
PORT=10004
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?appName=<appName>

# JWT Secret (MUST match root .env for socket auth)
JWT_SECRET=your_jwt_secret_here

# Email Configuration (Nodemailer SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=LAWNOVA Mock Trial <noreply@lawnova.com>

# Google Gemini API
GEMINI_API_KEY1=your_gemini_api_key_here

# Frontend URL (for invitation links)
FRONTEND_URL=http://localhost:3000

# Service Name
SERVICE_NAME=mocktrial-service

# Inter-Service Communication URLs
USER_SERVICE_URL=http://127.0.0.1:5005
AI_SERVICE_URL=http://127.0.0.1:5008
API_GATEWAY_URL=http://127.0.0.1:5000
INTERNAL_SERVICE_SECRET=your_internal_secret_here

# CORS Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:5000

# Transcription Engine (deepgram, aws, or default)
TRANSCRIPTION_ENGINE=deepgram

# Daily.co Video API
DAILY_API_KEY=your_daily_api_key_here
