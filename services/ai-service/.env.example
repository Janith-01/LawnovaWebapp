# Server Configuration
PORT=5008
PYTHON_AI_SERVICE_PORT=5009
NODE_ENV=development

# Internal Communication
INTERNAL_SERVICE_SECRET=your_internal_secret_here

# JWT Configuration (must match api-gateway and user-service)
JWT_SECRET=your_jwt_secret_here

# Google Gemini API
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_API_KEY1=your_gemini_api_key_backup_here

# Pinecone Vector Database
# Get your key at: https://app.pinecone.io/
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=lawnova-acts

# Mocktrial Service Connection
MOCKTRIAL_SERVICE_URL=http://localhost:10004

# Optional: Vertex AI Configuration
GOOGLE_CLOUD_PROJECT=your_project_id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=false

# Daily.co Video API
DAILY_API_KEY=your_daily_api_key_here
