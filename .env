# -------------------- Role Assignment Configuration --------------------
# Default role requirements per session
DEFAULT_JUDGE_COUNT=1
DEFAULT_LAWYER_COUNT=1
DEFAULT_OPPOSITION_LAWYER_COUNT=1
DEFAULT_CLIENT_COUNT=1
DEFAULT_WITNESS_COUNT=1

# Role assignment constraints
MAX_JUDGES_PER_SESSION=1
ENABLE_ROLE_OVERRIDE_BY_ADMIN=true

# Role history for fairness
TRACK_ROLE_HISTORY=true
ROLE_HISTORY_RETENTION_DAYS=365

# Auto-assign algorithm settings
AUTO_ASSIGN_ENABLED=true
USE_SEEDED_SHUFFLE_FOR_TIEBREAK=true
FAIR_ASSIGNMENT_ALGORITHM=fairness_weighted

# -------------------- Lobby Configuration --------------------
LOBBY_JOIN_WINDOW_MINUTES=30
LOBBY_GRACE_PERIOD_MINUTES=10
LOBBY_INACTIVITY_TIMEOUT_SECONDS=120
LOBBY_CLEANUP_INTERVAL_SECONDS=60
ENABLE_SOCKET_IO=true

# Lobby preferences
LOBBY_COUNTDOWN_INTERVAL_SECONDS=5
CAMERA_REQUIRED=true
MIC_REQUIRED=true

# -------------------- Socket.IO Configuration --------------------
SOCKET_PING_TIMEOUT=60000
SOCKET_PING_INTERVAL=25000

# -------------------- Security Configuration --------------------
BCRYPT_ROUNDS=10

# -------------------- Feature Flags --------------------
ENABLE_CHAT=true
ENABLE_OBJECTIONS=true
ENABLE_EVIDENCE_SHARING=true
ENABLE_PRIVATE_MESSAGES=true
ENABLE_TYPING_INDICATORS=true

# -------------------- Development Configuration --------------------
NODE_ENV=development
DEBUG=true
LOG_LEVEL=debug
LOG_FILE=./logs/app.log
LOG_FILE_PATH=logs/app.log
ENABLE_SWAGGER_DOCS=false

# -------------------- Rate Limiting --------------------
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX_REQUESTS=100

